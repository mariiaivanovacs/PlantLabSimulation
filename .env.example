# Flask settings
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# Port
PORT=8080

# Firebase — backend (Admin SDK uses service account)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CREDENTIALS_PATH=/path/to/service-account-key.json

# Firebase — Flutter web SDK (passed to flutter build web via build_web.sh)
# Find these in Firebase Console → Project settings → Your apps → Web app
FIREBASE_API_KEY=your-web-api-key
FIREBASE_APP_ID=1:your-sender-id:web:your-app-id-hash
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# CORS - specify allowed origins (comma-separated)
# For development: CORS_ORIGINS=*
# For production: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO

# BigQuery (if using)
BIGQUERY_PROJECT_ID=plant-lab-simulation-4e1c5
