# ─────────────────────────────────────────────────────────────────────────────
# PlantLabSimulation — environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase — backend (Admin SDK) ───────────────────────────────────────────
# Required. Find your project ID in Firebase Console → Project settings.
FIREBASE_PROJECT_ID=your-project-id

# Path to service-account JSON key file (local dev only).
# On Cloud Run, leave this unset — the app uses Application Default Credentials
# (ADC) from the Cloud Run service account automatically.
FIREBASE_CREDENTIALS_PATH=your-project-firebase-adminsdk-xxxx.json

# ── Firebase — Flutter web SDK ────────────────────────────────────────────────
# Passed to the Flutter build at compile time by build_web.sh (--dart-define).
# Find these in Firebase Console → Project settings → Your apps → Web app.
FIREBASE_API_KEY=your-web-api-key
FIREBASE_APP_ID=1:your-sender-id:web:your-app-id-hash
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Required for plant identification and AI health checks (/api/gemini/*).
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Stripe — billing ──────────────────────────────────────────────────────────
# Use TEST keys during development (no real charges).
# Get keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
# Webhook signing secret — for local testing run:
#   stripe listen --forward-to localhost:5010/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL of the deployed service (used by Stripe redirects + Flutter build).
# Leave empty for local dev — Flutter uses relative /api paths that resolve to
# the same Flask server automatically (same-origin, no CORS needed).
APP_URL=https://your-service-123456789.us-central1.run.app
# APP_URL=http://localhost:5010

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for /api/* routes.
# On Cloud Run, Flask serves both frontend and backend from the same URL
# (same-origin), so CORS is technically not required — but restricting it
# explicitly is good practice.
CORS_ORIGINS=https://your-service-123456789.us-central1.run.app,http://localhost:5010

# ── Flask / server ────────────────────────────────────────────────────────────
# Gunicorn / Cloud Run use PORT=8080 by default; local dev (run.py) uses 5010.
# Do not set PORT manually unless overriding the default.
FLASK_ENV=production
FLASK_DEBUG=False

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
