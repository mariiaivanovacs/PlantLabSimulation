# Flask settings
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# Port
PORT=8080

# Firebase
FIREBASE_PROJECT_ID=plant-lab-simulation-4e1c5
FIREBASE_CREDENTIALS_PATH=/path/to/service-account-key.json

# CORS - specify allowed origins (comma-separated)
# For development: CORS_ORIGINS=*
# For production: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO

# BigQuery (if using)
BIGQUERY_PROJECT_ID=plant-lab-simulation-4e1c5
